PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/cartcrew
MONGODB_URI_TEST=mongodb+srv://<user>:<password>@cluster.mongodb.net/cartcrew-test

JWT_SECRET=minimum_64_char_random_string_here
JWT_REFRESH_SECRET=different_64_char_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CLIENT_URL=http://localhost:5173
CORS_ORIGINS=

CLOUDINARY_CLOUD_NAME=your_cloud_name_from_cloudinary_dashboard
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

BCRYPT_ROUNDS=12
# Use 10 for test environments (faster hashing)
